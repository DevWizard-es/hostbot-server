# Variables de entorno para HostBot Server
# Copia este archivo como .env y rellena tus valores reales

# ── OpenRouter API ─────────────────────────────────────────────
# Obtenla en https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de IA a usar (puedes cambiarlo por cualquier modelo de OpenRouter)
AI_MODEL=openai/gpt-4o-mini

# ── Meta / Facebook ────────────────────────────────────────────
# Token de acceso de página de Facebook/Instagram
# Se obtiene en https://developers.facebook.com después de crear la app
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxx

# Token de verificación PARA el webhook (lo eliges tú, puede ser cualquier texto)
META_VERIFY_TOKEN=hostbot_webhook_secret_2024

# ── Configuración del negocio ──────────────────────────────────
# Nombre del negocio (aparece en las respuestas)
BUSINESS_NAME=Mi Negocio

# Tipo de negocio
BUSINESS_TYPE=Bar

# Descripción del negocio
BUSINESS_DESCRIPTION=Un lugar acogedor para disfrutar con amigos y familia.

# Dirección
BUSINESS_ADDRESS=Calle Ejemplo 123, Madrid

# Teléfono
BUSINESS_PHONE=+34 600 000 000

# Horario (texto libre)
BUSINESS_HOURS=Lunes a Viernes 08:00-23:00, Sábado y Domingo 10:00-24:00

# Menú (formato JSON en una sola línea - o deja en blanco y edita config/menu.json)
# Ejemplo: [{"category":"Bebidas","items":[{"name":"Café","price":"1.50"}]}]
BUSINESS_MENU=

# Tono del agente: friendly, formal, casual
AGENT_TONE=friendly

# Nombre del agente de IA
AGENT_NAME=Asistente

# Puerto del servidor (por defecto 3000)
PORT=3000
